@model ClienteModel
@{
    ViewData["Title"] = "Créer une carte fidélité";
}

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title">Créer une carte fidélité</h2>
                <div class="text-muted mt-1">Nouvelle inscription client</div>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                    <i class="ti ti-arrow-left me-1"></i> Retour
                </a>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">

        @if (ViewData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible" role="alert">
                <i class="ti ti-alert-circle me-2"></i>
                @ViewData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (ViewData["Success"] != null || TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible" role="alert">
                <i class="ti ti-circle-check me-2"></i>
                @(ViewData["Success"] ?? TempData["Success"])
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["CarteImageUrl"] != null)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <h3 class="card-title">Carte générée</h3>
                </div>
                <div class="card-body text-center">
                    <img src="@TempData["CarteImageUrl"]" alt="Carte" class="img-fluid border rounded" style="max-width: 600px;" />
                    <div class="mt-2">
                        <a href="@TempData["CarteImageUrl"]" target="_blank" class="btn btn-outline-primary btn-sm">
                            <i class="ti ti-external-link me-1"></i>Ouvrir l'image
                        </a>
                    </div>
                </div>
            </div>
        }

        <form asp-controller="Carte" asp-action="Creer" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">

                <!-- Colonne gauche -->
                <div class="col-lg-8">

                    <!-- Informations personnelles -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="ti ti-user me-2 text-primary"></i>Informations personnelles
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="form-label required">Nom</label>
                                    <input asp-for="Nom" class="form-control" placeholder="Nom de famille" />
                                    <span asp-validation-for="Nom" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Prénom</label>
                                    <input asp-for="Prenom" class="form-control" placeholder="Prénom" />
                                    <span asp-validation-for="Prenom" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">GSM</label>
                                    <input asp-for="Gsm" class="form-control" placeholder="06XXXXXXXX" maxlength="20" />
                                    <span asp-validation-for="Gsm" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">CIN</label>
                                    <input asp-for="Cin" class="form-control" placeholder="Numéro CIN" maxlength="20" required />
                                    <span asp-validation-for="Cin" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Email <span class="text-muted small">(optionnel)</span></label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="email@exemple.com" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Date de naissance</label>
                                    <input asp-for="DateNaissance" type="date" class="form-control" required
                                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="DateNaissance" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Genre</label>
                                    <select asp-for="RefGenreId" asp-items="ViewBag.Genres" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Ville</label>
                                    <select asp-for="RefVilleId" asp-items="ViewBag.Villes" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Adresse</label>
                                    <input asp-for="Adresse" class="form-control" placeholder="Adresse complète" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Informations professionnelles -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="ti ti-briefcase me-2 text-primary"></i>Informations professionnelles
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="form-label">Raison sociale</label>
                                    <input asp-for="RaisonSociale" class="form-control" placeholder="Nom entreprise ou société" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Fonction</label>
                                    <input asp-for="Fonction" class="form-control" placeholder="Poste / fonction" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Métier</label>
                                    <select asp-for="RefMetierId" asp-items="ViewBag.Metiers" class="form-select" required>
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                    <span asp-validation-for="RefMetierId" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label id="niaLabel" class="form-label">NIA</label>
                                    <input asp-for="Nia" type="number" class="form-control" placeholder="18 à 20 chiffres (obligatoire pour Artisan)"
                                           minlength="18" maxlength="20" />
                                    <span asp-validation-for="Nia" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Colonne droite -->
                <div class="col-lg-4">

                    <!-- Type de carte + Magasin -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="ti ti-credit-card me-2 text-primary"></i>Carte fidélité
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label required">Type de carte</label>
                                <select asp-for="RefCarteTypeId" asp-items="ViewBag.CarteTypes" class="form-select">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                                <span asp-validation-for="RefCarteTypeId" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label required">Magasin</label>
                                <select asp-for="RefMagasinId" asp-items="ViewBag.Magasins" class="form-select">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                                <span asp-validation-for="RefMagasinId" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Remarque</label>
                                <textarea asp-for="Remarque" class="form-control" rows="3" placeholder="Remarques éventuelles..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Info OTP -->
                    <div class="alert alert-info mb-3">
                        <div class="d-flex">
                            <i class="ti ti-info-circle me-2 mt-1"></i>
                            <div>
                                <strong>Workflow OTP</strong><br />
                                Après création, un OTP sera envoyé au GSM du client. Le client communique ce code au responsable pour confirmer la carte.
                            </div>
                        </div>
                    </div>

                    <!-- Bouton -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="ti ti-device-floppy me-2"></i>Créer la carte
                        </button>
                    </div>

                </div>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // NIA obligatoire (18-20 chiffres) uniquement pour la carte Artisan (RefCarteTypeId = 3)
        (function () {
            const typeSelect = document.getElementById("RefCarteTypeId");
            const niaInput = document.getElementById("Nia");
            const niaLabel = document.getElementById("niaLabel");
            if (!typeSelect || !niaInput || !niaLabel) return;

            function toggleNia() {
                const isArtisan = typeSelect.value === "3";
                niaInput.required = isArtisan;
                niaLabel.classList.toggle("required", isArtisan);
            }

            typeSelect.addEventListener("change", toggleNia);
            toggleNia();
        })();
    </script>
}
