@model BRICOMA.ECOMMERCE.Data.Models.RefCarteType
@{
    ViewData["Title"] = "Paramétrer le type de carte";
    var param = ViewBag.Parametrage as BRICOMA.ECOMMERCE.Data.Models.RefCarteTypeParametrage;
    var imageUrl = param != null && !string.IsNullOrWhiteSpace(param.ImagePath) ? "/" + param.ImagePath : null;
    var bx = param?.BarcodeX ?? 50;
    var by = param?.BarcodeY ?? 50;
    var bscale = param != null && param.BarcodeScale > 0 ? param.BarcodeScale : 100;
    var cardW = ViewBag.CardWidth != null ? (int)ViewBag.CardWidth : 2305;
    var cardH = ViewBag.CardHeight != null ? (int)ViewBag.CardHeight : 1427;
}

<div class="page-header mb-3">
    <div class="d-flex align-items-center gap-3">
        <span class="kpi-icon kpi-icon-lg" style="background:rgba(255,255,255,.18);color:#fff;">
            <i class="ti ti-adjustments"></i>
        </span>
        <div>
            <h2 class="page-title mb-0">Paramétrer « @Model.Name »</h2>
            <div class="text-muted mt-1">Gérez les paramètres de ce type de carte</div>
        </div>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-auto">
            <i class="ti ti-arrow-left me-1"></i> Retour
        </a>
    </div>
</div>

<form method="post" asp-action="Edit" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <input type="hidden" name="barcodeX" id="barcodeX" value="@bx" />
    <input type="hidden" name="barcodeY" id="barcodeY" value="@by" />
    <input type="hidden" name="barcodeScale" id="barcodeScale" value="@bscale" />
    <input type="hidden" name="removeImage" id="removeImage" value="false" />

    <div class="row g-3">
        <!-- Colonne gauche : champs -->
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Nom du type <span class="text-danger">*</span></label>
                        <input type="text" name="name" value="@Model.Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Message de réception</label>
                        <textarea name="messageReception" class="form-control" rows="4"
                                  placeholder="Message de confirmation envoyé au client après création de la carte (laisser vide pour le message par défaut).">@(param?.MessageReception)</textarea>
                        <div class="form-text">
                            Le code et le code-barres du client sont ajoutés automatiquement à la suite de ce message.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Image-modèle de la carte</label>
                        <input type="file" name="image" id="imageInput" class="form-control" accept=".png,.jpg,.jpeg"
                               data-card-w="@cardW" data-card-h="@cardH" />
                        <div class="form-text">
                            PNG ou JPG. Dimensions <strong>exactes obligatoires : @cardW × @cardH px</strong> (taille de la carte).
                            Laissez vide pour conserver l'image actuelle.
                        </div>
                        <div id="imageDimError" class="text-danger small mt-1"></div>
                    </div>

                    <button type="submit" id="btnSave" class="btn-gradient">
                        <i class="ti ti-device-floppy me-1"></i> Enregistrer
                    </button>
                </div>
            </div>
        </div>

        <!-- Colonne droite : aperçu + drag & drop -->
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h3 class="card-title mb-0">Position du code-barres</h3>
                        <span class="text-muted small">
                            X : <span id="lblX">@bx</span>% &nbsp;·&nbsp; Y : <span id="lblY">@by</span>%
                        </span>
                    </div>
                    <p class="text-muted small mb-3">
                        Glissez le code-barres de démonstration à l'endroit voulu sur l'image.
                        Le vrai code-barres du client sera généré à cette position lors de la création de la carte.
                    </p>

                    <div class="card-preview-shell">
                        <button type="button" id="btnDeleteImg" class="card-preview-del @(imageUrl == null ? "d-none" : "")"
                                title="Supprimer l'image">
                            <i class="ti ti-x"></i>
                        </button>
                        <div id="previewWrap" class="card-preview-wrap">
                            <div id="previewEmpty" class="card-preview-empty @(imageUrl != null ? "d-none" : "")">
                                <i class="ti ti-photo"></i>
                                <span>Aucune image — choisissez un fichier pour activer le positionnement</span>
                            </div>
                            <img id="previewImg" src="@imageUrl" class="card-preview-img @(imageUrl == null ? "d-none" : "")" alt="Modèle de carte" />
                            <div id="fakeBarcode" class="fake-barcode @(imageUrl == null ? "d-none" : "")"
                                 style="left:@(bx)%; top:@(by)%; --bc-scale:@(((decimal)bscale / 100).ToString(System.Globalization.CultureInfo.InvariantCulture));"
                                 title="Glissez-moi">
                                <div class="fake-barcode-bars"></div>
                                <div class="fake-barcode-text">0 000000 000000</div>
                            </div>
                        </div>
                    </div>

                    <!-- Taille (zoom) du code-barres -->
                    <div class="d-flex align-items-center gap-2 mt-3">
                        <i class="ti ti-zoom-in text-muted"></i>
                        <label for="barcodeSize" class="form-label mb-0 small text-muted" style="white-space:nowrap;">Taille du code-barres</label>
                        <input type="range" id="barcodeSize" class="form-range flex-grow-1" min="50" max="200" step="5" value="@bscale" />
                        <span class="badge bg-secondary" id="lblScale" style="min-width:3.2rem;">@bscale%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Modal : dimensions d'image invalides -->
<div class="modal fade" id="dimModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <i class="ti ti-photo-exclamation text-danger"></i> Image refusée
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">L'image choisie n'a pas les bonnes dimensions.</p>
                <p class="mb-2">
                    Dimensions du fichier : <strong id="dimGot" class="text-danger"></strong>
                </p>
                <p class="mb-0">
                    Dimensions <strong>exactes obligatoires</strong> :
                    <strong class="text-success">@cardW × @cardH px</strong> (taille de la carte).
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">J'ai compris</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const input = document.getElementById("imageInput");
            const img = document.getElementById("previewImg");
            const empty = document.getElementById("previewEmpty");
            const wrap = document.getElementById("previewWrap");
            const bc = document.getElementById("fakeBarcode");
            const inX = document.getElementById("barcodeX");
            const inY = document.getElementById("barcodeY");
            const lblX = document.getElementById("lblX");
            const lblY = document.getElementById("lblY");
            const btnDel = document.getElementById("btnDeleteImg");
            const inRemove = document.getElementById("removeImage");
            const slider = document.getElementById("barcodeSize");
            const inScale = document.getElementById("barcodeScale");
            const lblScale = document.getElementById("lblScale");
            const dimError = document.getElementById("imageDimError");
            const btnSave = document.getElementById("btnSave");
            const reqW = parseInt(input.getAttribute("data-card-w"), 10);
            const reqH = parseInt(input.getAttribute("data-card-h"), 10);
            const form = input.closest("form");
            let imageInvalid = false;

            function showDimModal(got) {
                const gotEl = document.getElementById("dimGot");
                if (gotEl) gotEl.textContent = got;
                const modalEl = document.getElementById("dimModal");
                if (modalEl && window.bootstrap) {
                    bootstrap.Modal.getOrCreateInstance(modalEl).show();
                }
            }

            // Aperçu de l'image choisie (un nouvel upload annule une suppression).
            // On vérifie d'abord que les dimensions correspondent EXACTEMENT à la carte.
            input.addEventListener("change", function () {
                dimError.textContent = "";
                btnSave.disabled = false;
                imageInvalid = false;
                const file = this.files && this.files[0];
                if (!file) return;

                const url = URL.createObjectURL(file);
                const probe = new Image();
                probe.onload = function () {
                    if (probe.naturalWidth !== reqW || probe.naturalHeight !== reqH) {
                        // Dimensions invalides : on refuse l'image, on bloque l'enregistrement
                        // et on affiche un modal qui rappelle la dimension exigée.
                        const got = probe.naturalWidth + " × " + probe.naturalHeight + " px";
                        dimError.textContent = "Image " + got + " refusée. Dimensions requises : " + reqW + " × " + reqH + " px.";
                        input.value = "";
                        btnSave.disabled = true;
                        imageInvalid = true;
                        URL.revokeObjectURL(url);
                        showDimModal(got);
                        return;
                    }
                    // Dimensions OK → aperçu + activation du positionnement.
                    img.src = url;
                    img.classList.remove("d-none");
                    empty.classList.add("d-none");
                    bc.classList.remove("d-none");
                    btnDel.classList.remove("d-none");
                    inRemove.value = "false";
                };
                probe.onerror = function () {
                    dimError.textContent = "Fichier image illisible.";
                    input.value = "";
                    btnSave.disabled = true;
                    imageInvalid = true;
                    URL.revokeObjectURL(url);
                };
                probe.src = url;
            });

            // Dernier rempart navigateur : empêche la soumission si l'image est invalide.
            if (form) {
                form.addEventListener("submit", function (e) {
                    if (imageInvalid) {
                        e.preventDefault();
                        showDimModal((dimError.textContent || "").trim());
                    }
                });
            }

            // Supprimer l'image : retire l'aperçu et réinitialise le champ fichier.
            // À l'enregistrement, l'image sera retirée tant qu'aucune autre n'est choisie.
            btnDel.addEventListener("click", function () {
                input.value = "";
                img.src = "";
                img.classList.add("d-none");
                bc.classList.add("d-none");
                btnDel.classList.add("d-none");
                empty.classList.remove("d-none");
                inRemove.value = "true";
            });

            // Zoom : taille du faux code-barres (et valeur sauvegardée).
            function applyScale(pct) {
                pct = Math.max(50, Math.min(200, pct));
                bc.style.setProperty("--bc-scale", (pct / 100).toString());
                inScale.value = pct;
                lblScale.textContent = pct + "%";
            }
            slider.addEventListener("input", function () {
                applyScale(parseInt(this.value, 10) || 100);
            });

            // Place le code-barres au centre (x,y en %) avec bornage
            function setPos(xp, yp) {
                xp = Math.max(0, Math.min(100, xp));
                yp = Math.max(0, Math.min(100, yp));
                bc.style.left = xp + "%";
                bc.style.top = yp + "%";
                inX.value = Math.round(xp);
                inY.value = Math.round(yp);
                lblX.textContent = Math.round(xp);
                lblY.textContent = Math.round(yp);
            }

            // Drag & drop (souris + tactile) du code-barres
            let dragging = false;

            function pointFromEvent(e) {
                const rect = wrap.getBoundingClientRect();
                const cx = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left;
                const cy = (e.touches ? e.touches[0].clientY : e.clientY) - rect.top;
                return { xp: cx / rect.width * 100, yp: cy / rect.height * 100 };
            }

            function startDrag(e) {
                if (bc.classList.contains("d-none")) return;
                dragging = true;
                bc.classList.add("dragging");
                e.preventDefault();
            }
            function moveDrag(e) {
                if (!dragging) return;
                const p = pointFromEvent(e);
                setPos(p.xp, p.yp);
                e.preventDefault();
            }
            function endDrag() {
                dragging = false;
                bc.classList.remove("dragging");
            }

            bc.addEventListener("mousedown", startDrag);
            document.addEventListener("mousemove", moveDrag);
            document.addEventListener("mouseup", endDrag);

            bc.addEventListener("touchstart", startDrag, { passive: false });
            document.addEventListener("touchmove", moveDrag, { passive: false });
            document.addEventListener("touchend", endDrag);

            // Clic direct sur l'image = déplacer le code-barres à cet endroit
            wrap.addEventListener("click", function (e) {
                if (bc.classList.contains("d-none") || e.target === bc || bc.contains(e.target)) return;
                if (e.target !== img) return;
                const p = pointFromEvent(e);
                setPos(p.xp, p.yp);
            });
        })();
    </script>
}
