@{
    ViewData["Title"] = "Nouveau type de carte";
}

<div class="page-header mb-3">
    <div class="d-flex align-items-center gap-3">
        <span class="kpi-icon kpi-icon-lg" style="background:rgba(255,255,255,.18);color:#fff;">
            <i class="ti ti-plus"></i>
        </span>
        <div>
            <h2 class="page-title mb-0">Nouveau type de carte</h2>
            <div class="text-muted mt-1">Ajouter un nouveau type de carte fidélité</div>
        </div>
        <a href="@Url.Action("Index", "Parametrage")" class="btn btn-outline-secondary ms-auto">
            <i class="ti ti-arrow-left me-1"></i> Retour
        </a>
    </div>
</div>


<div class="card" style="max-width:500px">
    <div class="card-body">
        <form method="post" asp-action="Create">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Nom du type <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" placeholder="Ex: Carte Gold" required />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn-gradient">
                    <i class="ti ti-plus me-1"></i> Créer
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>
