@model List<BRICOMA.ECOMMERCE.Data.Models.RefCarteType>
@{
    ViewData["Title"] = "Paramétrage — Types de cartes";
}

<div class="page-header mb-3">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title">Types de cartes</h2>
            <div class="text-muted mt-1">Paramétrage des types de cartes fidélité</div>
        </div>
        <div class="col-auto">
            <a href="@Url.Action("Create")" class="btn-gradient">
                <i class="ti ti-plus me-1"></i> Nouveau type
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-vcenter table-hover card-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">Aucun type de carte</td></tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">@item.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="avatar ic-teal" style="width:2.2rem;height:2.2rem;font-size:1rem;"><i class="ti ti-credit-card"></i></span>
                                    <span class="fw-bold">@item.Name</span>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn-soft btn-soft-indigo">
                                        <i class="ti ti-edit"></i> Modifier
                                    </a>
                                    <form method="post" asp-action="Delete" class="d-inline"
                                          data-confirm="Voulez-vous vraiment supprimer le type de carte « @item.Name » ? Cette action est irréversible."
                                          data-confirm-title="Supprimer ce type de carte ?"
                                          data-confirm-ok="Supprimer">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-soft btn-soft-red">
                                            <i class="ti ti-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
