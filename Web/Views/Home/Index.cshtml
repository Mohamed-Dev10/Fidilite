@model DashboardStatsModel
@{
    ViewData["Title"] = "Dashboard";
    var stats = Model ?? new DashboardStatsModel();
}

@{
    var sessionUser = User.Identity?.Name ?? "Utilisateur";
    var displayName = sessionUser.Contains('@') ? sessionUser.Split('@')[0] : sessionUser;
}
<div class="page-header d-print-none">
    <h2 class="page-title">Bonjour, @displayName</h2>
    <div class="page-subtitle">Vue d'ensemble des cartes fidélité</div>
</div>

<!-- KPI principaux (panneau teinté) -->
<div class="kpi-group kpi-group-indigo">
    <div class="kpi-group-head"><i class="ti ti-chart-pie"></i> Vue d'ensemble</div>
    <div class="row g-3">
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Total cartes</div>
                    <div class="kpi-value">@stats.TotalCartes</div>
                </div>
                <span class="kpi-icon ic-indigo"><i class="ti ti-id-badge"></i></span>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Créées ce mois</div>
                    <div class="kpi-value">@stats.CartesCeMois</div>
                </div>
                <span class="kpi-icon ic-blue"><i class="ti ti-calendar-plus"></i></span>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Cartes actives</div>
                    <div class="kpi-value">@stats.CartesActives</div>
                </div>
                <span class="kpi-icon ic-green"><i class="ti ti-circle-check"></i></span>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card">
                <div>
                    <div class="kpi-label">Cartes bloquées</div>
                    <div class="kpi-value">@stats.CartesBloquees</div>
                </div>
                <span class="kpi-icon ic-red"><i class="ti ti-lock"></i></span>
            </div>
        </div>
    </div>
</div>

<!-- KPI cliquables par type -->
<div class="row g-3 mb-2">
    <div class="col-md-6">
        <a href="@Url.Action("Index", "M3alem")" class="kpi-card is-link">
            <span class="kpi-icon kpi-icon-lg ic-blue me-1"><i class="ti ti-id-badge"></i></span>
            <div class="flex-grow-1">
                <div class="kpi-value">@stats.CartesM3alem</div>
                <div class="kpi-label mb-0">Cartes M3alem</div>
            </div>
            <i class="ti ti-chevron-right fs-3 text-blue"></i>
        </a>
    </div>
    <div class="col-md-6">
        <a href="@Url.Action("Index", "Artisan")" class="kpi-card is-link">
            <span class="kpi-icon kpi-icon-lg ic-orange me-1"><i class="ti ti-tool"></i></span>
            <div class="flex-grow-1">
                <div class="kpi-value">@stats.CartesArtisan</div>
                <div class="kpi-label mb-0">Cartes Artisan</div>
            </div>
            <i class="ti ti-chevron-right fs-3 text-orange"></i>
        </a>
    </div>
</div>

<!-- Répartition par magasin -->
@{
    var totalMagasin = stats.ParMagasin.Sum(m => m.Count);
    var topMagasins = stats.ParMagasin.OrderByDescending(m => m.Count).ToList();
    var maxMagasin = topMagasins.Any() ? topMagasins.Max(m => m.Count) : 0;
}
<div class="row row-cards">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-building-store me-2 text-primary"></i>Répartition par magasin</h3>
                <div class="card-actions">
                    <span class="badge bg-primary-lt">@stats.ParMagasin.Count magasin(s)</span>
                </div>
            </div>
            @if (!stats.ParMagasin.Any())
            {
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-icon"><i class="ti ti-database-off fs-1"></i></div>
                        <p class="empty-title">Aucune donnée</p>
                        <p class="empty-subtitle text-muted">Aucune carte n'est encore rattachée à un magasin.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="card-body">
                    <div class="rank-list">
                        @{ var rank = 0; }
                        @foreach (var m in topMagasins)
                        {
                            rank++;
                            var pct = maxMagasin > 0 ? (int)Math.Round(m.Count * 100.0 / maxMagasin) : 0;
                            var share = totalMagasin > 0 ? Math.Round(m.Count * 100.0 / totalMagasin, 1) : 0;
                            var rankClass = rank == 1 ? "is-1" : rank == 2 ? "is-2" : rank == 3 ? "is-3" : "";
                            <div class="rank-row">
                                <span class="rank-num @rankClass">@rank</span>
                                <div class="rank-main">
                                    <div class="rank-head">
                                        <span class="rank-name"><i class="ti ti-building-store"></i> @m.Magasin</span>
                                        <span class="rank-count">@m.Count <small class="text-muted">· @share%</small></span>
                                    </div>
                                    <div class="rank-bar">
                                        <span class="rank-bar-fill @rankClass" style="width:@(pct)%"></span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer text-muted">
                    Total : <strong>@totalMagasin</strong> carte(s) réparties sur <strong>@stats.ParMagasin.Count</strong> magasin(s)
                </div>
            }
        </div>
    </div>
</div>
