@model DashboardStatsModel
@{
    ViewData["Title"] = "Dashboard";
    var stats = Model ?? new DashboardStatsModel();
}

@{
    var sessionUser = User.Identity?.Name ?? "Utilisateur";
    var displayName = sessionUser.Contains('@') ? sessionUser.Split('@')[0] : sessionUser;
}
<div class="page-header d-print-none">
    <div class="d-flex align-items-center gap-3">
        <span class="kpi-icon kpi-icon-lg" style="background:rgba(255,255,255,.18);color:#fff;">
            <i class="ti ti-layout-dashboard"></i>
        </span>
        <div>
            <h2 class="page-title mb-0">Bonjour, @displayName</h2>
            @if (stats.SansMagasin)
            {
                <div class="text-muted mt-1" style="color:rgba(255,200,100,.9) !important;"><i class="ti ti-alert-triangle me-1"></i>Aucun magasin assigné à votre compte</div>
            }
            else if (!stats.EstGlobal)
            {
                <div class="text-muted mt-1"><i class="ti ti-building-store me-1"></i>Magasin : <strong style="color:#fff;">@stats.MagasinNom</strong></div>
            }
            else
            {
                <div class="text-muted mt-1">Vue d'ensemble des cartes fidélité</div>
            }
        </div>
    </div>
</div>

@if (stats.SansMagasin)
{
    <div class="card">
        <div class="card-body">
            <div class="empty">
                <div class="empty-icon"><i class="ti ti-building-store-off fs-1 text-warning"></i></div>
                <p class="empty-title">Aucun magasin assigné</p>
                <p class="empty-subtitle text-muted">
                    Votre compte n'est rattaché à aucun magasin, les statistiques ne peuvent donc pas être affichées.<br />
                    Contactez l'administrateur pour qu'il vous attribue un magasin.
                </p>
            </div>
        </div>
    </div>
    return;
}

<!-- KPI principaux — Vue d'ensemble -->
<fieldset class="kpi-fieldset">
    <legend class="kpi-legend"><i class="ti ti-chart-pie"></i> Vue d'ensemble</legend>
    <div class="row g-3">
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-cyan">
                <div class="kpi-anim-icon"><i class="ti ti-id-badge"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value" data-count="@stats.TotalCartes">0</div>
                    <div class="kpi-anim-label">Total cartes</div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-orange">
                <div class="kpi-anim-icon"><i class="ti ti-calendar-plus"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value" data-count="@stats.CartesCeMois">0</div>
                    <div class="kpi-anim-label">Créées ce mois</div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-teal">
                <div class="kpi-anim-icon"><i class="ti ti-circle-check"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value" data-count="@stats.CartesActives">0</div>
                    <div class="kpi-anim-label">Cartes actives</div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-red">
                <div class="kpi-anim-icon"><i class="ti ti-lock"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value" data-count="@stats.CartesBloquees">0</div>
                    <div class="kpi-anim-label">Cartes bloquées</div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
    </div>
</fieldset>

<!-- KPI cliquables par type -->
<fieldset class="kpi-fieldset">
    <legend class="kpi-legend"><i class="ti ti-credit-card"></i> Liste des cartes par type</legend>
    @{
        var typeAnimColors = new[] { "kpi-card-anim-blue", "kpi-card-anim-orange", "kpi-card-anim-teal", "kpi-card-anim-purple", "kpi-card-anim-green", "kpi-card-anim-pink" };
        var typeAnimIcons = new[] { "ti-id-badge", "ti-tool", "ti-diamond", "ti-star", "ti-award", "ti-crown" };
        var typeIdx = 0;
    }
    <div class="row g-3">
        @foreach (var type in stats.ParType)
        {
            var color = typeAnimColors[typeIdx % typeAnimColors.Length];
            var icon = typeAnimIcons[typeIdx % typeAnimIcons.Length];
            typeIdx++;
            <div class="col-sm-6 col-lg-3">
                <a href="@Url.Action("Liste", "Carte", new { typeId = type.TypeId })" class="kpi-card-animated @color" style="text-decoration:none;cursor:pointer;">
                    <div class="kpi-anim-icon"><i class="ti @icon"></i></div>
                    <div class="kpi-anim-body">
                        <div class="kpi-anim-value" data-count="@type.Count">0</div>
                        <div class="kpi-anim-label">@type.TypeName</div>
                    </div>
                    <i class="ti ti-chevron-right" style="font-size:1.5rem;color:var(--bc-muted);"></i>
                    <div class="kpi-anim-wave"></div>
                </a>
            </div>
        }
    </div>
</fieldset>

<!-- KPI animées : Activité récente -->
@{
    var weekDiff = stats.CartesSemainePrecedente > 0
        ? Math.Round((stats.CartesCetteSemaine - stats.CartesSemainePrecedente) * 100.0 / stats.CartesSemainePrecedente, 1)
        : (stats.CartesCetteSemaine > 0 ? 100.0 : 0);
    var weekUp = weekDiff >= 0;
}
<fieldset class="kpi-fieldset">
    <legend class="kpi-legend"><i class="ti ti-activity"></i> Activité récente</legend>
    <div class="row g-3">
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-blue">
                <div class="kpi-anim-icon"><i class="ti ti-sun"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value" data-count="@stats.CartesAujourdhui">0</div>
                    <div class="kpi-anim-label">Créées aujourd'hui</div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-indigo">
                <div class="kpi-anim-icon"><i class="ti ti-calendar-stats"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value" data-count="@stats.CartesCeMois">0</div>
                    <div class="kpi-anim-label">Créées ce mois</div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-purple">
                <div class="kpi-anim-icon"><i class="ti ti-chart-arrows-vertical"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value" data-count="@stats.CartesCetteSemaine">0</div>
                    <div class="kpi-anim-label">
                        Cette semaine
                        <span class="kpi-badge @(weekUp ? "kpi-badge-up" : "kpi-badge-down")">
                            <i class="ti @(weekUp ? "ti-trending-up" : "ti-trending-down")"></i> @(weekDiff > 0 ? "+" : "")@weekDiff%
                        </span>
                    </div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="kpi-card-animated kpi-card-anim-green">
                <div class="kpi-anim-icon"><i class="ti ti-shield-check"></i></div>
                <div class="kpi-anim-body">
                    <div class="kpi-anim-value kpi-anim-pct" data-count="@((int)stats.TauxActivation)">0</div>
                    <div class="kpi-anim-label">Taux d'activation</div>
                    <div class="kpi-anim-bar">
                        <div class="kpi-anim-bar-fill" style="--fill:@stats.TauxActivation%"></div>
                    </div>
                </div>
                <div class="kpi-anim-wave"></div>
            </div>
        </div>
    </div>
</fieldset>

<!-- Tendances : cartes créées par magasin, année en cours vs année précédente -->
@{
    var curYear = DateTime.Today.Year;
    var prevYear = curYear - 1;
}
@if (stats.EstGlobal && stats.ParMagasin.Any())
{
    @* Couleur stable par type (même type = même couleur sur toutes les lignes/magasins). *@
    var typeColorOf = stats.ParType
        .Select((t, i) => new { t.TypeId, Idx = i % 10 })
        .ToDictionary(x => x.TypeId, x => x.Idx);
    int ColorOf(int typeId) => typeColorOf.TryGetValue(typeId, out var idx) ? idx : 9;

    <fieldset class="kpi-fieldset">
        <legend class="kpi-legend"><i class="ti ti-chart-bar"></i> Tendances</legend>
        <div class="card card-trend">
            <div class="card-header card-trend-header">
                <span class="card-trend-icon"><i class="ti ti-chart-bar"></i></span>
                <div>
                    <h3 class="card-title mb-0">Cartes créées par magasin</h3>
                    <div class="text-muted small">@curYear vs @prevYear (même période, du 1er janvier à aujourd'hui)</div>
                </div>
            </div>
            <div class="card-body">
                @if (stats.ParType.Any())
                {
                    <div class="yearbar-type-legend mb-3">
                        @foreach (var t in stats.ParType)
                        {
                            <span class="yearbar-type-legend-item">
                                <span class="yearbar-legend-dot yearbar-seg-@ColorOf(t.TypeId)"></span>@t.TypeName
                            </span>
                        }
                    </div>
                }
                <div class="yearbar-list">
                    @{
                        var maxYearVal = stats.ParMagasin.Max(m => Math.Max(m.CountCurrentYear, m.CountPreviousYear));
                        if (maxYearVal < 1) { maxYearVal = 1; }
                    }
                    @foreach (var m in stats.ParMagasin)
                    {
                        <div class="yearbar-row">
                            <div class="yearbar-name" title="@m.Magasin">@m.Magasin</div>
                            <div class="yearbar-bars">
                                <div class="yearbar-track-row">
                                    <div class="yearbar-track yearbar-stacked">
                                        @foreach (var t in m.ParType.Where(t => t.CountCurrentYear > 0))
                                        {
                                            var segPct = t.CountCurrentYear * 100.0 / maxYearVal;
                                            <span class="yearbar-fill yearbar-seg-@ColorOf(t.TypeId)" data-width="@(segPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%" title="@t.TypeName : @t.CountCurrentYear"></span>
                                        }
                                    </div>
                                    <span class="yearbar-value">@m.CountCurrentYear</span>
                                    <span class="yearbar-year-tag">@curYear</span>
                                </div>
                                <div class="yearbar-track-row">
                                    <div class="yearbar-track yearbar-stacked">
                                        @foreach (var t in m.ParType.Where(t => t.CountPreviousYear > 0))
                                        {
                                            var segPct = t.CountPreviousYear * 100.0 / maxYearVal;
                                            <span class="yearbar-fill yearbar-seg-@ColorOf(t.TypeId) yearbar-seg-faded" data-width="@(segPct.ToString(System.Globalization.CultureInfo.InvariantCulture))%" title="@t.TypeName : @t.CountPreviousYear"></span>
                                        }
                                    </div>
                                    <span class="yearbar-value">@m.CountPreviousYear</span>
                                    <span class="yearbar-year-tag">@prevYear</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </fieldset>
}

@section Scripts {
    <script>
        // Barres "Cartes créées par magasin" : croissance animée en cascade à l'apparition.
        (function () {
            var bars = document.querySelectorAll(".yearbar-fill[data-width]");
            if (!bars.length) return;
            var obs = new IntersectionObserver(function (entries) {
                entries.forEach(function (e) {
                    if (!e.isIntersecting) return;
                    obs.unobserve(e.target);
                    e.target.style.width = e.target.getAttribute("data-width");
                });
            }, { threshold: 0.15 });
            bars.forEach(function (bar, i) {
                bar.style.transitionDelay = Math.min(i * 35, 700) + "ms";
                obs.observe(bar);
            });
        })();

        (function () {
            var els = document.querySelectorAll("[data-count]");
            if (!els.length) return;
            var obs = new IntersectionObserver(function (entries) {
                entries.forEach(function (e) {
                    if (!e.isIntersecting) return;
                    var el = e.target;
                    obs.unobserve(el);
                    var target = parseInt(el.getAttribute("data-count"), 10) || 0;
                    var isPct = el.classList.contains("kpi-anim-pct");
                    if (target === 0) { el.textContent = isPct ? "0%" : "0"; return; }
                    var dur = 1200, start = performance.now();
                    function tick(now) {
                        var t = Math.min((now - start) / dur, 1);
                        t = 1 - Math.pow(1 - t, 3);
                        var v = Math.round(t * target);
                        el.textContent = isPct ? v + "%" : v.toLocaleString("fr-FR");
                        if (t < 1) requestAnimationFrame(tick);
                    }
                    requestAnimationFrame(tick);
                });
            }, { threshold: 0.3 });
            els.forEach(function (el) { obs.observe(el); });
        })();
    </script>
}
