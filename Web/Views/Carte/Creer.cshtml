@model ClienteModel
@{
    ViewData["Title"] = "Créer une carte fidélité";
}

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="d-flex align-items-center gap-3">
            <span class="kpi-icon kpi-icon-lg" style="background:rgba(255,255,255,.18);color:#fff;">
                <i class="ti ti-id-badge"></i>
            </span>
            <div>
                <h2 class="page-title mb-0">Nouvelle carte fidélité</h2>
                <div class="text-muted mt-1">Inscription d'un nouveau client</div>
            </div>
            <a href="javascript:history.back()" class="btn btn-outline-secondary ms-auto">
                <i class="ti ti-arrow-left me-1"></i> Retour
            </a>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">

        @if (TempData["CarteImageUrl"] != null)
        {
            <div class="card mb-3">
                <div class="card-header">
                    <h3 class="card-title">Carte générée</h3>
                </div>
                <div class="card-body text-center">
                    <img src="@TempData["CarteImageUrl"]" alt="Carte" class="img-fluid border rounded" style="max-width: 600px;" />
                    <div class="mt-2">
                        <a href="@TempData["CarteImageUrl"]" target="_blank" class="btn btn-outline-primary btn-sm">
                            <i class="ti ti-external-link me-1"></i>Ouvrir l'image
                        </a>
                    </div>
                </div>
            </div>
        }

        <form asp-controller="Carte" asp-action="Creer" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="row g-3">

                <!-- Colonne gauche -->
                <div class="col-lg-8">

                    <!-- Informations personnelles -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title d-flex align-items-center gap-2">
                                <span class="avatar ic-indigo" style="width:2rem;height:2rem;font-size:.9rem;"><i class="ti ti-user"></i></span>
                                Informations personnelles
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="form-label required">Nom</label>
                                    <input asp-for="Nom" class="form-control" placeholder="Nom de famille" />
                                    <span asp-validation-for="Nom" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Prénom</label>
                                    <input asp-for="Prenom" class="form-control" placeholder="Prénom" />
                                    <span asp-validation-for="Prenom" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Téléphone</label>
                                    <input asp-for="Gsm" class="form-control" placeholder="10 chiffres (ex : 0612345678)"
                                           maxlength="10" inputmode="numeric" autocomplete="tel" />
                                    <span asp-validation-for="Gsm" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">CIN</label>
                                    <input asp-for="Cin" class="form-control" placeholder="8 caractères" maxlength="8" />
                                    <span asp-validation-for="Cin" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Email <span class="text-muted small">(optionnel)</span></label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="email@exemple.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Date de naissance</label>
                                    @{
                                        var dnHasValue = Model != null && Model.DateNaissance > DateTime.MinValue;
                                        var dnIso = dnHasValue ? Model!.DateNaissance.ToString("yyyy-MM-dd") : "";
                                        var dnDisp = dnHasValue ? Model!.DateNaissance.ToString("dd/MM/yyyy") : "jj/mm/aaaa";
                                    }
                                    <div class="dp" data-dp data-max="today" data-exclude-today>
                                        <input type="hidden" id="DateNaissance" name="DateNaissance" value="@dnIso" />
                                        <button type="button" class="form-control input-date dp-trigger" aria-haspopup="dialog">
                                            <span class="dp-value @(dnHasValue ? "" : "is-placeholder")">@dnDisp</span>
                                        </button>
                                        <div class="dp-pop" hidden></div>
                                    </div>
                                    <span asp-validation-for="DateNaissance" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Métier</label>
                                    <select asp-for="RefMetierId" asp-items="ViewBag.Metiers" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                    <span asp-validation-for="RefMetierId" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Genre</label>
                                    <select asp-for="RefGenreId" asp-items="ViewBag.Genres" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Ville</label>
                                    <select asp-for="RefVilleId" asp-items="ViewBag.Villes" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Adresse</label>
                                    <input asp-for="Adresse" class="form-control" placeholder="Adresse complète" />
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Colonne droite -->
                <div class="col-lg-4">

                    <!-- Type de carte + Magasin -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title d-flex align-items-center gap-2">
                                <span class="avatar ic-teal" style="width:2rem;height:2rem;font-size:.9rem;"><i class="ti ti-credit-card"></i></span>
                                Carte fidélité
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label required">Type de carte</label>
                                <select asp-for="RefCarteTypeId" asp-items="ViewBag.CarteTypes" class="form-select">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                                <span asp-validation-for="RefCarteTypeId" class="text-danger small"></span>
                            </div>
                            <!-- NIA : affiché uniquement pour la carte Artisan -->
                            <div class="mb-3" id="niaBlock" hidden>
                                <label id="niaLabel" class="form-label required">NIA</label>
                                <input asp-for="Nia" type="number" class="form-control" placeholder="18 à 20 chiffres (obligatoire pour Artisan)" />
                                <span asp-validation-for="Nia" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label required">Magasin</label>
                                <select asp-for="RefMagasinId" asp-items="ViewBag.Magasins" class="form-select">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                                <span asp-validation-for="RefMagasinId" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Remarque</label>
                                <textarea asp-for="Remarque" class="form-control" rows="3" placeholder="Remarques éventuelles..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Info OTP -->
                    <div class="otp-callout mb-3">
                        <span class="avatar ic-blue" style="width:2.2rem;height:2.2rem;flex:0 0 auto;"><i class="ti ti-message-2-code"></i></span>
                        <div>
                            <div class="fw-bold mb-1">Workflow OTP</div>
                            <div class="text-muted small">Après création, un code OTP est envoyé au GSM du client. Il communique ce code au responsable pour confirmer la carte.</div>
                        </div>
                    </div>

                    <!-- Bouton -->
                    <div class="d-grid">
                        <button type="submit" class="btn-gradient" style="padding:.8rem 1.2rem;font-size:1.05rem;">
                            <i class="ti ti-device-floppy me-2"></i>Créer la carte
                        </button>
                    </div>

                </div>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/datepicker.js"></script>
    <script src="~/js/carte-form.js"></script>
}
