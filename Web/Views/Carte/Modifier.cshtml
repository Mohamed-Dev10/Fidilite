@model ClienteModel
@{
    ViewData["Title"] = "Modifier la carte";
}

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title">Modifier la carte</h2>
                <div class="text-muted mt-1">@Model.Code</div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">

        <form asp-controller="Carte" asp-action="Modifier" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Code" />
            <input type="hidden" asp-for="CodeBarre" />

            <div class="row g-3">

                <!-- Colonne gauche -->
                <div class="col-lg-8">

                    <!-- Informations personnelles -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="ti ti-user me-2 text-primary"></i>Informations personnelles
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="form-label required">Nom</label>
                                    <input asp-for="Nom" class="form-control" />
                                    <span asp-validation-for="Nom" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Prénom</label>
                                    <input asp-for="Prenom" class="form-control" />
                                    <span asp-validation-for="Prenom" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">GSM</label>
                                    <input asp-for="Gsm" class="form-control" placeholder="06XXXXXXXX" maxlength="20" />
                                    <span asp-validation-for="Gsm" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">CIN</label>
                                    <input asp-for="Cin" class="form-control" maxlength="20" required />
                                    <span asp-validation-for="Cin" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Email</label>
                                    <input asp-for="Email" type="email" class="form-control" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Date de naissance</label>
                                    <input asp-for="DateNaissance" type="date" class="form-control" required
                                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Genre</label>
                                    <select asp-for="RefGenreId" asp-items="ViewBag.Genres" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Ville</label>
                                    <select asp-for="RefVilleId" asp-items="ViewBag.Villes" class="form-select">
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Adresse</label>
                                    <input asp-for="Adresse" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Informations professionnelles -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="ti ti-briefcase me-2 text-primary"></i>Informations professionnelles
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="form-label">Raison sociale</label>
                                    <input asp-for="RaisonSociale" class="form-control" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Fonction</label>
                                    <input asp-for="Fonction" class="form-control" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label required">Métier</label>
                                    <select asp-for="RefMetierId" asp-items="ViewBag.Metiers" class="form-select" required>
                                        <option value="">-- Sélectionner --</option>
                                    </select>
                                    <span asp-validation-for="RefMetierId" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label id="niaLabel" class="form-label">NIA</label>
                                    <input asp-for="Nia" type="number" class="form-control" minlength="18" maxlength="20" />
                                    <span asp-validation-for="Nia" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Colonne droite -->
                <div class="col-lg-4">

                    <!-- Identifiants figés -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="ti ti-barcode me-2 text-primary"></i>Identifiants
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Code client</label>
                                <input class="form-control" value="@Model.Code" disabled />
                            </div>
                            <div class="mb-0">
                                <label class="form-label">Code-barres</label>
                                <input class="form-control" value="@Model.CodeBarre" disabled />
                            </div>
                            <div class="text-muted small mt-2">
                                <i class="ti ti-lock me-1"></i>Code et code-barres ne sont pas modifiables.
                            </div>
                        </div>
                    </div>

                    <!-- Type de carte + Magasin -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="ti ti-credit-card me-2 text-primary"></i>Carte fidélité
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label required">Type de carte</label>
                                <select asp-for="RefCarteTypeId" asp-items="ViewBag.CarteTypes" class="form-select">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                            <div class="mb-0">
                                <label class="form-label required">Magasin</label>
                                <select asp-for="RefMagasinId" asp-items="ViewBag.Magasins" class="form-select">
                                    <option value="">-- Sélectionner --</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn-gradient" style="padding:.8rem 1.2rem;font-size:1.05rem;">
                            <i class="ti ti-device-floppy me-2"></i>Enregistrer
                        </button>
                    </div>

                </div>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // NIA obligatoire (18-20 chiffres) uniquement pour la carte Artisan (RefCarteTypeId = 3)
        (function () {
            const typeSelect = document.getElementById("RefCarteTypeId");
            const niaInput = document.getElementById("Nia");
            const niaLabel = document.getElementById("niaLabel");
            if (!typeSelect || !niaInput || !niaLabel) return;

            function toggleNia() {
                const isArtisan = typeSelect.value === "3";
                niaInput.required = isArtisan;
                niaLabel.classList.toggle("required", isArtisan);
            }

            typeSelect.addEventListener("change", toggleNia);
            toggleNia();
        })();
    </script>
}
