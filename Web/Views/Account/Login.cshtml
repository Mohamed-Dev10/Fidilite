@model BRICOMA.ECOMMERCE.Models.Models.LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<div class="auth-wrap">
    <!-- Panneau marque -->
    <aside class="auth-hero">
        <div class="auth-brand">
          
            <span class="auth-brand-logo"><img src="~/images/bricoma.png" alt="BRICOMA" /></span>
        </div>

        <div class="auth-hero-body">
            <h2 class="auth-hero-title">Back Office Clients</h2>
            <p class="auth-hero-sub">Gérez vos cartes de fidélité, vos magasins et vos clients depuis un espace unique et sécurisé.</p>
            <ul class="auth-features">
                <li><i class="ti ti-id-badge"></i> Création et suivi des cartes en temps réel</li>
             
                <li><i class="ti ti-shield-lock"></i> Accès sécurisé par rôles et permissions</li>
            </ul>
        </div>

        <div class="auth-foot">© @DateTime.Now.Year BRICOMA · Tous droits réservés</div>
        <div class="auth-bubbles" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
        </div>
    </aside>

    <!-- Panneau formulaire — image carte + champs superposés -->
    <main class="auth-form-side">
        <div class="auth-carte-wrap">
            <img src="~/images/carte-form.png" class="auth-carte-img" alt="" draggable="false" />
            <div class="auth-carte-tagline">
                <span>Création &amp; suivi</span>
                <span>de cartes Fidélité</span>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-carte-alert">
                    <i class="ti ti-alert-triangle"></i>
                    @Html.ValidationSummary(false)
                </div>
            }

            <form class="auth-carte-form" method="post" asp-action="Login" asp-controller="Account">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="auth-carte-field">
                    <i class="ti ti-mail"></i>
                    <input type="email" asp-for="Email" placeholder="Email" autocomplete="email" />
                    <span asp-validation-for="Email" class="auth-carte-err"></span>
                </div>
                <div class="auth-carte-field">
                    <i class="ti ti-lock"></i>
                    <input type="password" asp-for="Password" placeholder="Mot de passe" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="auth-carte-err"></span>
                </div>
                <button type="submit" class="auth-carte-btn">
                    <i class="ti ti-login"></i> Se connecter
                </button>
            </form>
        </div>
    </main>
</div>
