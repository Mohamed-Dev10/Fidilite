@{
    ViewData["Title"] = "Vérification OTP";
    var token = ViewBag.Token as string;
    var gsm = ViewBag.Gsm as string;
}

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title">Vérification du code OTP</h2>
                <div class="text-muted mt-1">Saisissez le code reçu par WhatsApp pour finaliser la carte</div>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <a asp-action="Creer" class="btn btn-outline-secondary">
                    <i class="ti ti-arrow-left me-1"></i> Annuler
                </a>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="card">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <span class="avatar avatar-lg ic-green">
                                <i class="ti ti-brand-whatsapp" style="font-size: 1.8rem;"></i>
                            </span>
                        </div>
                        <h3 class="card-title">Code envoyé au @gsm</h3>
                        <p class="text-muted">
                            Le client a reçu un code à 6 chiffres par WhatsApp.
                            Saisissez-le ci-dessous (valable 10 minutes).
                        </p>

                        <form asp-action="VerifierOtp" method="post" class="mt-4">
                            <input type="hidden" name="token" value="@token" />
                            <input type="hidden" name="gsm" value="@gsm" />

                            <div class="mb-3">
                                <input type="text" name="otpCode" class="form-control form-control-lg text-center"
                                       inputmode="numeric" maxlength="6" autocomplete="one-time-code"
                                       placeholder="● ● ● ● ● ●" autofocus required
                                       style="letter-spacing: 0.5rem; font-size: 1.5rem;" />
                            </div>

                            <button type="submit" class="btn-gradient w-100">
                                <i class="ti ti-circle-check me-1"></i> Vérifier et créer la carte
                            </button>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <form asp-action="RenvoyerOtp" method="post" class="d-inline">
                        <input type="hidden" name="token" value="@token" />
                        <input type="hidden" name="gsm" value="@gsm" />
                        <span class="text-muted">Code non reçu ?</span>
                        <button type="submit" id="resendBtn" class="btn btn-link p-0 align-baseline">
                            <i class="ti ti-refresh me-1"></i><span id="resendLabel">Renvoyer le code</span>
                        </button>
                    </form>
                    <div class="mt-1">
                        <a asp-action="Creer" class="text-muted small">Recommencer la saisie</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Anti-spam : on bloque le renvoi pendant 30 s après l'affichage de la page.
        (function () {
            const btn = document.getElementById("resendBtn");
            const label = document.getElementById("resendLabel");
            if (!btn || !label) return;

            let remaining = 30;
            const baseText = "Renvoyer le code";
            btn.disabled = true;

            const timer = setInterval(function () {
                remaining -= 1;
                if (remaining <= 0) {
                    clearInterval(timer);
                    btn.disabled = false;
                    label.textContent = baseText;
                } else {
                    label.textContent = baseText + " (" + remaining + "s)";
                }
            }, 1000);
            label.textContent = baseText + " (" + remaining + "s)";
        })();
    </script>
}
