@model BRICOMA.ECOMMERCE.Models.Models.LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

<div class="auth-wrap">
    <!-- Panneau marque -->
    <aside class="auth-hero">
        <div class="auth-brand">
            <span class="auth-brand-logo"><img src="~/images/bricoma.png" alt="BRICOMA" /></span>
            <span class="auth-brand-name">BRICOMA</span>
        </div>

        <div class="auth-hero-body">
            <h2 class="auth-hero-title">Back Office Client</h2>
            <p class="auth-hero-sub">Gérez vos cartes de fidélité, vos magasins et vos clients depuis un espace unique et sécurisé.</p>
            <ul class="auth-features">
                <li><i class="ti ti-id-badge"></i> Création et suivi des cartes en temps réel</li>
             
                <li><i class="ti ti-shield-lock"></i> Accès sécurisé par rôles et permissions</li>
            </ul>
        </div>

        <div class="auth-foot">© @DateTime.Now.Year BRICOMA · Tous droits réservés</div>
        <div class="auth-bubbles" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span>
        </div>
    </aside>

    <!-- Panneau formulaire -->
    <main class="auth-form-side">
        <div class="auth-card">
            <div class="auth-mobile-brand">
                <span class="auth-brand-logo"><img src="~/images/bricoma.png" alt="BRICOMA" style="width:100%;height:100%;object-fit:contain;display:block;" /></span> BRICOMA
            </div>

            <div class="auth-card-head">
                <h1>Bienvenue</h1>
                <p>Connectez-vous à votre espace back-office.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-modern alert-modern-danger" role="alert">
                    <span class="am-ic"><i class="ti ti-alert-triangle"></i></span>
                    <div class="am-body">@Html.ValidationSummary(false)</div>
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Account">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="auth-field">
                    <label class="form-label">Email</label>
                    <i class="ti ti-mail"></i>
                    <input type="email" asp-for="Email" class="form-control" placeholder="votre@email.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="auth-field">
                    <label class="form-label">Mot de passe</label>
                    <i class="ti ti-lock"></i>
                    <input type="password" asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-gradient w-100 mt-2">
                    <i class="ti ti-login me-1"></i> Se connecter
                </button>
            </form>
        </div>
    </main>
</div>
