@model BRICOMA.ECOMMERCE.Data.ApplicationUser.ApplicationRole
@{
    ViewData["Title"] = "Assigner permissions";
    var allPermissions = ViewBag.AllPermissions as List<BRICOMA.ECOMMERCE.Data.ApplicationUser.Permission> ?? new();
    var assignedIds = ViewBag.AssignedIds as List<int> ?? new();
    var categories = allPermissions.Select(p => p.Category).Distinct().OrderBy(c => c).ToList();
    var palette = new[] { "indigo", "purple", "blue", "orange", "red", "green", "teal", "pink", "cyan", "yellow" };
}

<div class="page-header mb-3">
    <div class="row align-items-center">
        <div class="col-auto">
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
                <i class="ti ti-arrow-left me-1"></i> Retour
            </a>
        </div>
        <div class="col">
            <h2 class="page-title">Permissions — @Model.Name</h2>
            <div class="text-muted">@(Model.Description ?? "")</div>
        </div>
    </div>
</div>

<form method="post" asp-action="AssignerPermissions" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()

    <div class="row">
        @for (int ci = 0; ci < categories.Count; ci++)
        {
            var category = categories[ci];
            var color = palette[ci % palette.Length];
            var count = allPermissions.Count(p => p.Category == category);
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-header">
                        <span class="avatar ic-@color me-2" style="width:2.2rem;height:2.2rem;font-size:1rem;"><i class="ti ti-category"></i></span>
                        <div>
                            <h3 class="card-title">@category</h3>
                            <div class="text-muted small">@count permission(s)</div>
                        </div>
                    </div>
                    <div class="card-body">
                        @foreach (var perm in allPermissions.Where(p => p.Category == category))
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox"
                                       name="permissionIds"
                                       value="@perm.Id"
                                       id="perm_@perm.Id"
                                       @(assignedIds.Contains(perm.Id) ? "checked" : "") />
                                <label class="form-check-label" for="perm_@perm.Id">
                                    <span class="fw-medium">@perm.Label</span>
                                    <br /><small class="text-muted">@perm.Code</small>
                                </label>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-2 d-flex gap-2">
        <button type="submit" class="btn-gradient">
            <i class="ti ti-device-floppy me-1"></i> Enregistrer
        </button>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>
