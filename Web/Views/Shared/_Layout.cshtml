@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    string Active(string c) => string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BRICOMA</title>
    <link rel="stylesheet" href="~/lib/tabler-icons/css/tabler-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/css/app-theme.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <div class="app-wrapper">

        <!-- Top navbar -->
        <nav class="app-header navbar navbar-expand bg-body shadow-sm">
            <div class="container-fluid">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                            <i class="ti ti-menu-2 fs-3"></i>
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a href="#" class="nav-link d-flex align-items-center" data-bs-toggle="dropdown">
                            <span class="avatar bg-primary text-white me-2"><i class="ti ti-user"></i></span>
                            <span class="d-none d-md-block text-start">
                                <span class="d-block fw-bold lh-1">@User.Identity?.Name</span>
                                <span class="d-block small text-muted">BRICOMA</span>
                            </span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end shadow">
                            <form method="post" asp-controller="Account" asp-action="Logout">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="ti ti-logout me-2"></i> Déconnexion
                                </button>
                            </form>
                        </div>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Sidebar -->
        <aside class="app-sidebar shadow" data-bs-theme="dark">
            <div class="sidebar-brand">
                <a asp-controller="Home" asp-action="Index" class="brand-link">
                    <span class="brand-text fw-bold">BRICOMA</span>
                </a>
            </div>
            <div class="sidebar-wrapper">
                <nav class="mt-2 flex-grow-1">
                    <ul class="nav sidebar-menu flex-column" role="menu">
                        <li class="nav-item">
                            <a asp-controller="Home" asp-action="Index" class="nav-link si-indigo @Active("Home")">
                                <i class="nav-icon ti ti-layout-dashboard"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <li class="nav-header">Cartes Fidélité</li>
                        <li class="nav-item">
                            <a asp-controller="Carte" asp-action="Creer" class="nav-link si-green @Active("Carte")">
                                <i class="nav-icon ti ti-plus"></i>
                                <p>Nouvelle carte</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="M3alem" asp-action="Index" class="nav-link si-blue @Active("M3alem")">
                                <i class="nav-icon ti ti-id-badge"></i>
                                <p>Cartes M3alem</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Artisan" asp-action="Index" class="nav-link si-orange @Active("Artisan")">
                                <i class="nav-icon ti ti-tool"></i>
                                <p>Cartes Artisan</p>
                            </a>
                        </li>

                        @{
                            var canUsers = User.HasClaim("perm", "admin.users");
                            var canParam = User.HasClaim("perm", "parametrage.view");
                            var canRoles = User.HasClaim("perm", "admin.roles");
                        }
                        @if (canParam || canRoles)
                        {
                            <li class="nav-header">Configuration</li>
                        }
                        @if (canParam)
                        {
                            <li class="nav-item">
                                <a asp-controller="Parametrage" asp-action="Index" class="nav-link si-teal @Active("Parametrage")">
                                    <i class="nav-icon ti ti-settings"></i>
                                    <p>Paramétrage</p>
                                </a>
                            </li>
                        }
                        @if (canRoles)
                        {
                            <li class="nav-item">
                                <a asp-controller="GestionPermissions" asp-action="Index" class="nav-link si-purple @Active("GestionPermissions")">
                                    <i class="nav-icon ti ti-shield-lock"></i>
                                    <p>Gestion de permissions</p>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>

                @{
                    var userName = User.Identity?.Name ?? "Utilisateur";
                    var initials = string.Concat(userName.Split(new[] { ' ', '.', '@' }, StringSplitOptions.RemoveEmptyEntries)
                                        .Take(2).Select(p => char.ToUpper(p[0])));
                    if (string.IsNullOrEmpty(initials)) { initials = "U"; }
                }
                <div class="sidebar-profile">
                    <span class="sp-avatar">@initials</span>
                    <div class="overflow-hidden">
                        <div class="sp-name text-truncate">@userName</div>
                        <div class="sp-role">BRICOMA</div>
                    </div>
                    <form method="post" asp-controller="Account" asp-action="Logout" class="ms-auto d-flex">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="sp-logout" title="Déconnexion">
                            <i class="ti ti-logout fs-5"></i>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main content -->
        <main class="app-main">
            <div class="app-content">
                <div class="container-fluid py-3">
                    @RenderBody()
                </div>
            </div>
        </main>

        <!-- Footer -->
        <footer class="app-footer d-print-none">
            <div class="text-muted">&copy; 2026 BRICOMA. Tous droits réservés.</div>
        </footer>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/adminlte/js/adminlte.min.js"></script>
    <script src="~/js/app-popup.js"></script>
    <partial name="_Toasts" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
