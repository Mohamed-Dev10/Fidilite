@{
    ViewData["Title"] = "Nouveau type de carte";
}

<div class="page-header mb-3">
    <div class="row align-items-center">
        <div class="col-auto">
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
                <i class="ti ti-arrow-left me-1"></i> Retour
            </a>
        </div>
        <div class="col">
            <h2 class="page-title">Nouveau type de carte</h2>
        </div>
    </div>
</div>

@if (ViewData["Error"] != null)
{
    <div class="alert alert-danger">@ViewData["Error"]</div>
}

<div class="card" style="max-width:500px">
    <div class="card-body">
        <form method="post" asp-action="Create">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Nom du type <span class="text-danger">*</span></label>
                <input type="text" name="name" class="form-control" placeholder="Ex: Carte Gold" required />
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-plus me-1"></i> Créer
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary ms-2">Annuler</a>
        </form>
    </div>
</div>
